# =============================================
# giua@school - Configurazione Produzione
# =============================================
# Copia questo file in .env e personalizza i valori
#
#   cp .env.production.example .env
#   nano .env
#   docker compose -f docker-compose.production.yml up -d
# =============================================

# ─── DOMINIO ───
# Il dominio su cui sarà raggiungibile il registro
DOMAIN=registro.efor.it
# Dominio dedicato al backend legacy Symfony/Twig
LEGACY_DOMAIN=legacy.registro.efor.it

# ─── CLOUDFLARE TUNNEL ───
# Ottieni il token da: https://one.dash.cloudflare.com/
# Zero Trust → Networks → Tunnels → Create a tunnel → "registro-efor"
# Copia il token dalla schermata di installazione
CLOUDFLARE_TUNNEL_TOKEN=CAMBIAMI_token_dal_dashboard_cloudflare

# ─── SSL / LET'S ENCRYPT ───
# Email per i certificati SSL (riceverai notifiche di scadenza)
ACME_EMAIL=admin@tuascuola.it

# ─── DATABASE ───
DB_NAME=giuaschool
DB_USER=giuaschool
DB_PASSWORD=CAMBIAMI_password_sicura_123!
DB_ROOT_PASSWORD=CAMBIAMI_root_password_456!
# Se =1 inizializza automaticamente schema + dati base su volume DB vuoto
AUTO_INIT_DB=1

# ─── SYMFONY ───
# Genera con: php -r "echo bin2hex(random_bytes(16));"
# oppure:     openssl rand -hex 16
APP_SECRET=CAMBIAMI_genera_un_secret_hex_32
JWT_PASSPHRASE=CAMBIAMI_passphrase_jwt_lunga_e_sicura

# ─── TRAEFIK DASHBOARD (opzionale) ───
# Genera con: htpasswd -nB admin
# oppure:     echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
# Formato: utente:hash_password (i $ vanno raddoppiati $$)
# Esempio sotto: admin / admin (DA CAMBIARE!)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$example_hash_change_me
