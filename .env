# .env

### definisce l'ambiente correntemente utilizzato
APP_ENV=dev

### abilita il debug
APP_DEBUG=1

### codice segreto univoco usato nella gestione della sicurezza
APP_SECRET='DevSecretKeyChangeInProduction'

### parametri di connessione al database
DATABASE_URL='mysql://giuaschool:giuaschool@db:3306/giuaschool'

### parametri di connessione al server email
MAILER_DSN='php://default'

### parametri di configurazione per l'invio dei messaggi
MESSENGER_TRANSPORT_DSN='doctrine://default'

### autenticazione tramite Google Workspace
GOOGLE_API_KEY=''
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''
GOOGLE_AUTH_CONFIG=''
OAUTH_GOOGLE_CLIENT_ID=''
OAUTH_GOOGLE_CLIENT_SECRET=''
OAUTH_GOOGLE_CLIENT_HD=''

### imposta il livello del log del sistema in produzione
LOG_LEVEL='debug'

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME_IN_DOTENV_LOCAL
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

NEXTJS_URL=http://localhost:3000
